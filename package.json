{
  "name": "mfe-dashboard",
  "version": "1.0.0",
  "description": "Микрофронтенды на Vue 3, Vite, Module Federation и Turborepo",
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "concurrently \"pnpm dev:host\" \"pnpm dev:remote\"",
    "dev:host": "turbo run dev --filter=@mfe-dashboard/host --parallel",
    "dev:remote": "turbo run preview --filter=@mfe-dashboard/remote-products --filter=@mfe-dashboard/remote-sales-graph --filter=@mfe-dashboard/remote-weather --filter=@mfe-dashboard/remote-currency-rate --parallel",
    "dev:api": "json-server --watch db.json --port 3001",
    "build:remote": "turbo run build --filter=@mfe-dashboard/remote-products --filter=@mfe-dashboard/remote-sales-graph --filter=@mfe-dashboard/remote-weather --filter=@mfe-dashboard/remote-currency-rate",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.3.5",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "prettier": "^3.2.4",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vue-tsc": "^2.2.0",
    "concurrently": "^9.1.0",
    "json-server": "^1.0.0-beta.1"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18"
  }
}